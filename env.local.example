# Renombra este archivo a .env.local antes de ejecutar `npm run dev`.
#
# EmailJS — formulario de contacto
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# URL canónica del sitio (para metadata + Open Graph)
NEXT_PUBLIC_SITE_URL=https://sergio-portfolio.vercel.app
